# ── 메일(SMTP) — Gmail 발송 ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=__gmail_app_password__
NEWS_MAIL_FROM=your@gmail.com
# 수신자(콤마로 여러 명)
NEWS_MAIL_TO=your@gmail.com

# ── 뉴스 설정 ─────────────────────────────────────────
# 검색 키워드(콤마구분). 각 키워드로 Google 뉴스를 검색해 모읍니다.
NEWS_KEYWORDS=농구,KBL,WKBL,NBA,유소년 농구,용산중 농구,용산고 농구
# 최근 몇 시간 내 기사만 (기본 24시간). 결과가 없으면 자동으로 최신 기사로 대체.
NEWS_HOURS=24
# 키워드별 최대 표시 개수
NEWS_MAX_PER_KEYWORD=6
# 주간 단위로만 포함할 키워드(콤마구분). 나머지는 매일. 포함일엔 지난 NEWS_WEEKLY_DAYS치를 한 번에.
NEWS_WEEKLY_KEYWORDS=
NEWS_WEEKLY_DAYS=7
# 메일 하단 '용산 소식' 챕터로 묶을 키워드(매일). 신석=감독, 이정석=코치.
NEWS_YONGSAN_KEYWORDS=용산중 농구,용산고 농구,신석 농구,이정석 농구
# 용산 기사는 최근 이 일수 이내만(없으면 표시 안 함).
NEWS_YONGSAN_DAYS=7
